POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
# Password for the read-only role the AI service uses to read backend tables.
AI_READONLY_PASSWORD=change-me-readonly-pass
# Password for ai_user — owns the AI service's own database (ai_appdb).
AI_DB_PASSWORD=change-me-ai-db-pass
AI_SERVICE_TOKEN=paste-the-generated-token-here
# Base URL of the frontend nginx serves in this stack — used to build
# clickable verify-email/reset-password links in emails (core/views/auth.py,
# see ../Frontend-Email-Handoff.md). Defaults to :8080 (this stack's nginx)
# if unset.
FRONTEND_URL=http://localhost:8080

# SeaweedFS (staging/prod: the seaweedfs service in deploy/docker-compose.yml
# — its endpoint is a fixed internal URL, hardcoded in the compose file
# itself like AI_SERVICE_URL, not read from env)
SEAWEED_ACCESS_KEY=paste-the-generated-access-key-here
SEAWEED_SECRET_KEY=paste-the-generated-secret-key-here

# ── Mock Bank OAuth+OTP service + ledger (mock-bank-oauth/, mock-bank-sync/,
# in-repo) — see the mock-bank-oauth/mock-bank-sync blocks in
# deploy/docker-compose.yml. mock-bank-oauth's /authorize page is NOT yet
# publicly reachable in this stack (no nginx route, no published port) —
# MOCK_BANK_OAUTH_PUBLIC_URL will need a real value once that's wired up.
MOCK_BANK_OAUTH_CLIENT_ID=nbe-backend
MOCK_BANK_OAUTH_CLIENT_SECRET=change-me-mock-bank-client-secret
MOCK_BANK_OAUTH_REDIRECT_URI=http://localhost:8080/bank-connect/callback
MOCK_BANK_OAUTH_PUBLIC_URL=http://localhost:8002
# mock-bank-oauth's own Gmail account, for sending OTP emails directly — a
# real Gmail/Workspace account + an App Password (Google Account > Security
# > 2-Step Verification > App Passwords), not a real user password.
MOCK_BANK_OAUTH_GMAIL_ADDRESS=your-demo-account@gmail.com
MOCK_BANK_OAUTH_GMAIL_APP_PASSWORD=change-me-app-password
# Shared only between mock-bank-oauth and mock-bank-sync — this backend
# never sees either, since it treats their access token as fully opaque.
MOCK_BANK_INTERNAL_SECRET=change-me-mock-bank-internal-secret
MOCK_BANK_JWT_SECRET=change-me-mock-bank-jwt-secret
# Checked against mock-bank-sync's X-Webhook-Secret when it pushes to this
# backend's POST /webhooks/bank-sync/.
BANK_SYNC_WEBHOOK_SECRET=change-me-bank-sync-webhook-secret
# Password for mock_bank_user — owns mock-bank-sync's own database (mock_bank_db).
MOCK_BANK_DB_PASSWORD=change-me-mock-bank-db-pass

USE_MOCK_LLM=1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-key-or-leave-blank-when-USE_MOCK_LLM=1
MODEL_NAME=gpt-4o-mini
# Concurrent LLM calls / per-chunk token ceiling for AI statement normalization.
NORMALIZATION_MAX_PARALLEL_CHUNKS=1
NORMALIZATION_CHUNK_MAX_TOKENS=4096

# ── AI service object storage (buckets on the same SeaweedFS gateway above) ──
# The AI service never creates these buckets — `manage.py ensure_storage_buckets`
# (run by the backend service on boot) creates all three via
# services/storage_backends.py's STORAGE_CLASSES. Reuse those exact names.
AI_STORAGE_BUCKET=pfm-statements-normalized
AI_STORAGE_OCR_BUCKET=pfm-statements-ocr

# ── MinerU (document processing) — real service is PARKED, see the mineru:
# block in deploy/docker-compose.yml. Stays mocked until an image is chosen.
USE_MOCK_MINERU=1
MINERU_API_URL=http://mineru:8000
MINERU_API_KEY=change-me-mineru-key

# ── vLLM (staging/prod, GPU only) ─────────────────────────────────────────────
# To enable: set USE_MOCK_LLM=0 and point OPENAI_BASE_URL at the vLLM service.
# Uncomment the vllm: block in deploy/docker-compose.yml and see VLLM_RUNBOOK.md.
# OPENAI_BASE_URL=http://vllm:8000/v1
# MODEL_NAME=<model-name-chosen-by-AI-team>
