POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
# Password for the read-only role the AI service uses to read backend tables.
AI_READONLY_PASSWORD=change-me-readonly-pass
# Password for ai_user — owns the AI service's own database (ai_appdb).
AI_DB_PASSWORD=change-me-ai-db-pass
AI_SERVICE_TOKEN=paste-the-generated-token-here
USE_MOCK_LLM=1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-key-or-leave-blank-when-USE_MOCK_LLM=1
MODEL_NAME=gpt-4o-mini

# ── vLLM (staging/prod, GPU only) ─────────────────────────────────────────────
# To enable: set USE_MOCK_LLM=0 and point OPENAI_BASE_URL at the vLLM service.
# Uncomment the vllm: block in deploy/docker-compose.yml and see VLLM_RUNBOOK.md.
# OPENAI_BASE_URL=http://vllm:8000/v1
# MODEL_NAME=<model-name-chosen-by-AI-team>
