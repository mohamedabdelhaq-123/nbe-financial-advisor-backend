# ── Django ────────────────────────────────────────────────────────────────────
# Secret key — change in any non-local environment.
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173

# ── Postgres ──────────────────────────────────────────────────────────────────
# DB/USER/PASSWORD are required (must match the postgres service + deploy/initdb).
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
# HOST defaults to the compose service name; for host-run against a locally
# exposed postgres use `localhost`.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── AI service ────────────────────────────────────────────────────────────────
# Bearer token the backend sends when proxying to the AI service (core/ask_view.py).
AI_SERVICE_TOKEN=token
# URL the backend proxies /ask to.
AI_SERVICE_URL=http://localhost:8001
# Password for the ai_readonly DB role, applied by
# core/migrations/0009_grant_ai_readonly_role.py.
AI_READONLY_PASSWORD=change-me-readonly-pass
# Password for the ai_user DB role, provisioned by deploy/initdb (not app-read).
AI_DB_PASSWORD=change-me-ai-db-pass

# ── SeaweedFS (S3-compatible Filer gateway, dev: seaweedfs service on :8333) ──
SEAWEED_S3_ENDPOINT=http://seaweedfs:8333
SEAWEED_ACCESS_KEY=dev-seaweed-key
SEAWEED_SECRET_KEY=dev-seaweed-secret

# ── Redis / Celery / SSE ──────────────────────────────────────────────────────
# Defaults point at the compose `redis` service.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
# Run tasks synchronously in-process (useful for host-run without a worker).
# 0 = off (normal async behavior).
CELERY_TASK_ALWAYS_EAGER=0
SSE_TICKET_TTL_SECONDS=30
