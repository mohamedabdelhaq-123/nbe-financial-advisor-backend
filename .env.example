# ── Django ────────────────────────────────────────────────────────────────────
# Secret key — change in any non-local environment.
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173
# Base URL used to build clickable verify-email/reset-password links in
# emails (core/views/auth.py) — see Frontend-Email-Handoff.md (one level up).
FRONTEND_URL=http://localhost:5173

# ── Postgres ──────────────────────────────────────────────────────────────────
# DB/USER/PASSWORD are required (must match the postgres service + deploy/initdb).
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
# HOST defaults to the compose service name; for host-run against a locally
# exposed postgres use `localhost`.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── AI service ────────────────────────────────────────────────────────────────
# Bearer token sent to the AI service (services/ai_service.py, core/ask_view.py).
AI_SERVICE_TOKEN=token
# Base URL of the AI service. Host-run Django (manage.py runserver, pytest,
# celery -A config) reaches a host-run ai-service directly at localhost:8001.
# Running via `docker compose up` instead, the backend/celery-worker containers
# override this to http://host.docker.internal:8001 (see docker-compose.yml) —
# "localhost" from inside a container means the container itself, not the host.
AI_SERVICE_URL=http://localhost:8001
# Toggles services/ai_service.py between an in-process mock (deterministic,
# no network — the default, so dev/test never needs a live ai-service) and
# real HTTP calls to AI_SERVICE_URL. Set to 0 once ai-service is up.
USE_MOCK_AI_SERVICE=1
# Password for the ai_readonly DB role, applied by
# core/migrations/0009_grant_ai_readonly_role.py.
AI_READONLY_PASSWORD=change-me-readonly-pass
# Password for the ai_user DB role, provisioned by deploy/initdb (not app-read).
AI_DB_PASSWORD=change-me-ai-db-pass

# ── Mock Bank OAuth+OTP service (mock-bank-oauth/, in-repo) ────────────────────
# Server-to-server address (token exchange, account/transaction fetches) —
# reached from inside the Docker network.
MOCK_BANK_OAUTH_SERVICE_URL=http://mock-bank-oauth:8002
MOCK_BANK_OAUTH_CLIENT_ID=nbe-backend
MOCK_BANK_OAUTH_CLIENT_SECRET=dev-mock-bank-client-secret
MOCK_BANK_OAUTH_REDIRECT_URI=http://localhost:5173/bank-connect/callback
# Browser-facing address for the authorize_url handed to the frontend — the
# user's browser navigates here directly, so this must be reachable from
# the host/wherever the frontend runs, never the Docker service name.
MOCK_BANK_OAUTH_PUBLIC_URL=http://localhost:8002
# mock-bank-oauth's own Gmail account, for sending OTP emails directly — a
# real Gmail/Workspace account + an App Password (Google Account > Security
# > 2-Step Verification > App Passwords), not a real user password. Not read
# by Django; consumed by mock-bank-oauth's own container.
MOCK_BANK_OAUTH_GMAIL_ADDRESS=your-demo-account@gmail.com
MOCK_BANK_OAUTH_GMAIL_APP_PASSWORD=dummy-app-password
# GET /debug/challenges/{id} on mock-bank-oauth — reads a generated OTP
# without a real email gateway (used by tests/integration/). Not read by
# Django; consumed by mock-bank-oauth's own container. Defaults off inside
# that service; this only takes effect because docker-compose.yml sets it.
MOCK_BANK_OAUTH_ENABLE_DEBUG_ENDPOINTS=1

# ── Mock Bank Sync service (mock-bank-sync/, in-repo) ───────────────────────────
MOCK_BANK_SYNC_SERVICE_URL=http://mock-bank-sync:8003
BANK_SYNC_WEBHOOK_SECRET=dev-bank-sync-webhook-secret
# Not read by Django — shared only between mock-bank-oauth and mock-bank-sync
# themselves (token signing/verification, and mock-bank-oauth's customer
# lookup call). Set identically on both of those services' own environments
# (docker-compose.yml passes the same values to both containers).
MOCK_BANK_JWT_SECRET=dev-mock-bank-jwt-secret
MOCK_BANK_INTERNAL_SECRET=dev-mock-bank-internal-secret
# Password for the mock_bank_user DB role (mock-bank-sync's own database),
# provisioned by deploy/initdb/20-mock-bank-roles.sh — same pattern as
# AI_DB_PASSWORD above.
MOCK_BANK_DB_PASSWORD=change-me-mock-bank-db-pass

# ── Notification (Gmail SMTP, see services/notification_service.py) ────────────
# An existing Gmail/Workspace account + an App Password (Google Account →
# Security → 2-Step Verification → App Passwords). Demo-appropriate: no
# signup/domain-verification friction, unlike a dedicated ESP.
GMAIL_ADDRESS=your-demo-account@gmail.com
GMAIL_APP_PASSWORD=dummy-app-password

# ── SeaweedFS (S3-compatible Filer gateway, dev: seaweedfs service on :8333) ──
SEAWEED_S3_ENDPOINT=http://seaweedfs:8333
SEAWEED_ACCESS_KEY=dev-seaweed-key
SEAWEED_SECRET_KEY=dev-seaweed-secret

# ── Redis / Celery / SSE ──────────────────────────────────────────────────────
# Defaults point at the compose `redis` service.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
# Run tasks synchronously in-process (useful for host-run without a worker).
# 0 = off (normal async behavior).
CELERY_TASK_ALWAYS_EAGER=0
SSE_TICKET_TTL_SECONDS=30
